{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@elo/core": ["packages/core/src/index.ts"],
      "@elo/ui": ["packages/ui/src/index.ts"],
      "@elo/config/*": ["packages/config/*"]
    }
  }
}
